# ===========================================
# SmartFinance / SmartWallet - Environment
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env - it contains secrets.

# Auth (required for JWT)
# JWT_SECRET=your-256-bit-secret-at-least-32-chars
# JWT_EXPIRATION_SECONDS=86400

# Production: enables startup checks (strong JWT). Omit for local dev.
# SPRING_PROFILES_ACTIVE=prod

# Production CORS: comma-separated origin patterns (override default localhost + Vercel/Netlify/Expo)
# CORS_ALLOWED_ORIGINS=https://your-app.onrender.com,https://*.vercel.app

# Database: local Docker (default) or Supabase Postgres
# DB_URL=jdbc:postgresql://localhost:5432/smartwallet
# DB_USERNAME=smartwallet
# DB_PASSWORD=smartwallet

# For Supabase Postgres — prefer Transaction pooler (port 6543) for servers (Render).
# Session/direct (5432) hits "MaxClientsInSessionMode" easily. In Supabase: Database →
# Connection string → "Transaction pooler" → build JDBC, e.g.:
# DB_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
# DB_USERNAME=postgres.PROJECT_REF   (or value Supabase shows for the pooler)
# DB_PASSWORD=your-database-password
#
# Optional: cap pool size on small Supabase tiers / Render:
# HIKARI_MAX_POOL_SIZE=5

# AI Insights - Groq first, then Hugging Face fallback:
# Groq (free): console.groq.com
# GROQ_API_KEY=gsk_...

# Hugging Face (free fallback): huggingface.co/settings/tokens (Inference Providers permission)
# HF_TOKEN=hf_...

# OpenAI (paid, optional)
# OPENAI_API_KEY=sk-...

# Local dev only: Ollama (brew install ollama && ollama run llama3.2)
# OLLAMA_URL=http://localhost:11434

# Receipt storage: local (default), s3, or supabase
# STORAGE_PROVIDER=local

# For S3 (AWS):
# STORAGE_PROVIDER=s3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_PREFIX=receipts/
# Notes (free tier-friendly):
# - Use a single bucket + prefix to stay within free limits (5GB standard).
# - If you want receipt URLs to load directly, allow public read on the receipts prefix
#   (or keep the bucket private and proxy downloads through the API).
# - Add a lifecycle rule to expire old receipts if needed.

# For Azure Blob Storage:
# STORAGE_PROVIDER=azure
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=receipts
# AZURE_STORAGE_BLOB_PREFIX=receipts/
# The container must allow public blob reads if receipt URLs are displayed directly.

# For Supabase (no credit card for free tier):
# STORAGE_PROVIDER=supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKET=receipts
# SUPABASE_STORAGE_PREFIX=

# RabbitMQ - local (Docker) or CloudAMQP (free, no card)
# Local: docker-compose up -d, uses guest/guest@localhost:5672
# Cloud: CloudAMQP - see docs/RABBITMQ-CLOUD-SETUP.md
# RABBITMQ_URI=amqps://user:pass@host.cloudamqp.com/vhost
#
# Hosts without RabbitMQ (e.g. Render until you add CloudAMQP): disable so the API starts and listens on PORT
# RABBITMQ_ENABLED=false
# Or Spring-style (same effect): SPRING_RABBITMQ_ENABLED=false

# Frontend (Expo): set this in app/.env (see app/.env.example) — NOT here.
# Root .env is for the Java backend only; Expo reads app/.env

# CORS - comma-separated origin patterns (default: localhost + Vercel, Netlify, Expo)
# CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,https://your-app.vercel.app

# Rate limiting (per-IP, token bucket). Default: 100 req/min.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_CAPACITY=100
# RATE_LIMIT_REFILL_MINUTES=1
# RATE_LIMIT_EXCLUDE_PATHS=/health,/actuator/health,/actuator/info
